# Local development (matches docker-compose.yml defaults)
DATABASE_URL=postgresql://dev:dev@localhost:5433/dharma_streams

# Better Auth — session signing secret + canonical app URL
# Generate a secret with: openssl rand -hex 32
BETTER_AUTH_SECRET=change-me-before-deploying
BETTER_AUTH_URL=http://localhost:3000

# Remote admin API — for Cursor / local scripts updating production
# Generate with: openssl rand -hex 32
# Set the same value on Coolify and in local .env.local
# ADMIN_API_KEY=
# REMOTE_APP_URL=https://your-domain.com

# Optional — higher website recovery via Places API (New)
# GOOGLE_PLACES_API_KEY=
