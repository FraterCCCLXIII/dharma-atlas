# =============================================================================
# Coolify environment variables — copy into Coolify → Application → Environment
# Generate secrets: openssl rand -hex 32
# =============================================================================

# --- Required ---

# Postgres connection (Coolify Postgres service internal URL)
# Example: postgresql://dharma:YOUR_PASSWORD@postgres-xxx:5432/dharma_streams
DATABASE_URL=

# Public URL of the deployed app (no trailing slash)
BETTER_AUTH_URL=https://your-domain.com

# Session signing secret (openssl rand -hex 32)
BETTER_AUTH_SECRET=

# Remote admin API key for Cursor / npm run cloud (openssl rand -hex 32)
ADMIN_API_KEY=

# --- Runtime ---

NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0

# --- Optional ---

# GOOGLE_PLACES_API_KEY=
# GOOGLE_GEOCODING_API_KEY=

# --- Local only (not set on Coolify) ---

# REMOTE_APP_URL=https://your-domain.com
