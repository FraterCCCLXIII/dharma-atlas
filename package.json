{
  "name": "dharma-centers",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "import-data": "node scripts/import-kml.mjs",
    "import-sources": "PYTHONUNBUFFERED=1 python3 scripts/import-sources.py",
    "export-teachers": "node scripts/export-teachers.mjs",
    "download-teacher-photos": "tsx scripts/download-teacher-photos.ts",
    "sync-teacher-photo-paths": "tsx scripts/sync-teacher-photo-paths.ts",
    "sync-place-photo-paths": "tsx scripts/sync-place-photo-paths.ts",
    "apply-schools": "node scripts/apply-manual-schools.mjs",
    "enrich-data": "PYTHONUNBUFFERED=1 python3 scripts/enrich-places.py",
    "audit-places": "PYTHONUNBUFFERED=1 python3 scripts/audit-places.py",
    "clean-places": "PYTHONUNBUFFERED=1 python3 scripts/clean-places.py",
    "recover-source-urls": "PYTHONUNBUFFERED=1 python3 scripts/recover-source-urls.py",
    "enrich-google-places": "PYTHONUNBUFFERED=1 python3 scripts/enrich-google-places.py",
    "discover-google-places": "bash -c 'set -a; [ -f .env.local ] && source .env.local; set +a; PYTHONUNBUFFERED=1 python3 scripts/discover-google-places.py \"$@\"' --",
    "export-places": "tsx scripts/export-places.ts",
    "download-place-photos": "tsx scripts/download-place-photos.ts",
    "pipeline:places": "node scripts/pipeline-places.mjs",
    "pipeline:places:full": "node scripts/pipeline-places.mjs --full",
    "pipeline:continue": "bash scripts/pipeline-continue.sh",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx scripts/seed-from-json.ts",
    "db:studio": "drizzle-kit studio",
    "auth:create-owner": "tsx scripts/create-owner.ts"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "better-auth": "^1.6.22",
    "drizzle-orm": "^0.45.2",
    "leaflet": "^1.9.4",
    "motion": "^12.41.0",
    "next": "16.2.9",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-leaflet": "^5.0.0",
    "server-only": "^0.0.1",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.21",
    "@tailwindcss/postcss": "^4",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
